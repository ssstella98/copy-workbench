{
  "version": "1.0",
  "description": "Producer Copy Key generation rules — machine-readable config for the Copy Workbench demo",
  "keyFormat": {
    "structure": ["Domain", "Page", "Module", "Title", "Body"],
    "separator": ".",
    "casing": "CamelCase",
    "noChinese": true
  },
  "domain": {
    "label": "Domain",
    "definition": "项目/业务标识",
    "generationRule": "project_fixed",
    "customizable": false,
    "examples": ["HMH", "Refund", "PFC"]
  },
  "page": {
    "label": "Page",
    "definition": "具体页面",
    "generationRule": "auto_from_figma_frame_name",
    "customizable": true,
    "maxWords": 3,
    "language": "en",
    "description": "直接读取 Figma Frame 名称：英文直接用（CamelCase，≤3词）；中文翻译为英文后使用",
    "examples": {
      "HMH Home Page": "HomePage",
      "HMH Check Out Page": "CheckOutPage",
      "Payment Page": "PaymentPage",
      "首页": "HomePage",
      "结算页": "CheckOutPage",
      "支付": "PaymentPage"
    },
    "cleanupRules": [
      "Strip common project prefixes (HMH, PFC, Refund etc.)",
      "Remove spaces, hyphens, underscores",
      "Convert to CamelCase",
      "Max 3 English words",
      "If Chinese, use title.translationMap to translate"
    ]
  },
  "module": {
    "label": "Module",
    "definition": "功能模块或独立文案点位，按UI交互方式判断",
    "generationRule": "auto_detect_from_ui_type",
    "customizable": false,
    "enums": {
      "Layer": {
        "description": "容器/层级",
        "values": ["Modal", "Sheet", "PoPup"]
      },
      "Navigation": {
        "description": "导航",
        "values": ["NavigationBar"]
      },
      "Feedback": {
        "description": "反馈",
        "values": ["Toast", "ActionBar"]
      },
      "Form": {
        "description": "表单控件",
        "values": ["Switch", "RadioButton", "Checkbox", "TextField", "Dropdown", "Capsule", "Calendar"]
      },
      "Function": {
        "description": "功能入口",
        "values": ["Icon", "Button", "Hyperlink"]
      },
      "Content": {
        "description": "文本内容",
        "values": ["Placeholder", "Label", "Title", "Subtitle", "Notes", "Tooltip"]
      },
      "Layout": {
        "description": "布局/业务模块",
        "values": ["Banner", "ToDoList", "KeyEntrance", "Upsell", "Activity", "Facility", "TopTips"]
      }
    },
    "detectionKeywords": {
      "Modal": ["确认", "取消", "关闭", "知道了", "确定"],
      "Sheet": ["抽屉", "面板"],
      "Toast": ["成功", "失败", "已", "提示"],
      "ActionBar": ["去支付", "提交订单", "立即预订", "确认支付", "购买"],
      "Button": ["按钮", "支付", "下单", "购买", "预订", "立即", "确认", "提交", "取消", "返回"],
      "Placeholder": ["请输入", "请选择", "输入"],
      "Label": [":", "："],
      "Title": ["title", "标题"],
      "Hyperlink": ["了解更多", "查看详情", "查看更多", "查看全部", "详情"],
      "NavigationBar": ["门票", "餐饮", "房间", "交通", "设施", "活动", "商城", "权益", "我的", "首页"],
      "KeyEntrance": ["支付", "下单", "预订", "购买", "提交", "确认支付", "去支付"],
      "Upsell": ["推荐", "云闪付", "银联", "优惠", "折扣", "立减", "精选", "热门"],
      "Activity": ["活动", "演出", "巡游", "烟花", "派对", "节日", "庆典"],
      "Facility": ["行李寄存", "行李", "寄存", "健身房", "泳池", "餐厅", "SPA", "接送", "巴士"],
      "TopTips": ["须知", "提示", "注意", "公告", "提醒"],
      "ToDoList": ["登记", "匹配", "预约", "添加", "管理行程"],
      "Banner": ["欢迎", "特选", "享受", "体验", "Explore"]
    }
  },
  "title": {
